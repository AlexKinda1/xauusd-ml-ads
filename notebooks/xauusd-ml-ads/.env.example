# Copy this file to .env and fill in your own keys.
# .env is gitignored — never commit real secrets.

# FRED API (https://fred.stlouisfed.org/docs/api/api_key.html)
# Free, required for: DXY, US 10Y yield, CPI, Fed Funds rate, real rates.
FRED_API_KEY=

# Alpha Vantage (optional, https://www.alphavantage.co/support/#api-key)
# Backup source for macro variables. Free tier: 25 req/day.
ALPHAVANTAGE_API_KEY=

# NewsAPI (optional, https://newsapi.org/)
# For news sentiment. Free tier: 1 month historical only.
NEWSAPI_KEY=

# MLflow tracking URI (default: ./mlruns)
MLFLOW_TRACKING_URI=./mlruns
